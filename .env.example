# PostgreSQL
POSTGRES_USER=erp
POSTGRES_PASSWORD=erp_pass
POSTGRES_DB=erp_nfc
DATABASE_URL=postgresql+psycopg://erp:erp_pass@localhost:5432/erp_nfc

# 외부 공공 API (data.go.kr 등에서 발급)
KMA_API_KEY=
HOLIDAY_API_KEY=

# AI 해석 provider (gemini | ollama | rule)
LLM_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# 로컬 LLM (Ollama)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
